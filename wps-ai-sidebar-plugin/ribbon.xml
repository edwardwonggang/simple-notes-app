<customUI xmlns="http://schemas.microsoft.com/office/2006/01/customui" onLoad="OnAddinLoad">
    <ribbon startFromScratch="false">
        <tabs>
            <tab id="wpsAiSidebarTab" label="AI 写作助手">
				<group id="aiSidebarMainGroup" label="侧栏操作">
                    <button id="btnToggleSidebar" label="打开侧栏" onAction="OnAction" getImage="GetImage" visible="true" size="large"/>
                    <button id="btnRefreshSelection" label="读取选区" onAction="OnAction" getImage="GetImage" visible="true" size="large"/>
                    <button id="btnCopyLastReply" label="复制最近回复" onAction="OnAction" getImage="GetImage" visible="true" size="large"/>
				</group>
                <group id="aiSidebarQuickGroup" label="一键处理">
                    <button id="btnQuickSummarize" label="一键总结" onAction="OnAction" getImage="GetImage" visible="true" size="large"/>
                    <button id="btnQuickPolish" label="一键润色" onAction="OnAction" getImage="GetImage" visible="true" size="large"/>
                    <button id="btnQuickTranslate" label="一键翻译" onAction="OnAction" getImage="GetImage" visible="true" size="large"/>
                    <button id="btnQuickFormalize" label="正式化" onAction="OnAction" getImage="GetImage" visible="true" size="large"/>
				</group>
                <group id="aiSidebarInsertGroup" label="结果回填">
                    <button id="btnInsertLastReply" label="插入到光标" onAction="OnAction" getImage="GetImage" visible="true" size="large"/>
                    <button id="btnReplaceSelection" label="替换选区" onAction="OnAction" getImage="GetImage" visible="true" size="large"/>
				</group>
            </tab>
        </tabs>
    </ribbon>
</customUI>
